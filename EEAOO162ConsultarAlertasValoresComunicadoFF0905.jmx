          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="GUS.SERVICE_AUDIT_RESPONSE | GUS.SERVICE_AUDIT ">
            <stringProp name="dataSource">DEV_GUS_APP</stringProp>
            <stringProp name="query">SELECT 
    sur.ID_SERVICE_AUDIT_RESPONSE,
    sur.RESPONSE_DATE,
    DBMS_LOB.SUBSTR(sur.RESPONSE, 2000, 1) AS RESPONSE,
    sur.METADATA_RESPONSE,
    sa.*
FROM GUS.SERVICE_AUDIT_RESPONSE sur
INNER JOIN GUS.SERVICE_AUDIT sa
    ON sur.ID_SERVICE_AUDIT_RESPONSE = sa.ID_SERVICE_AUDIT
WHERE sur.METADATA_RESPONSE LIKE &apos;%who(${NISS_EE})%&apos;
  AND sur.METADATA_RESPONSE LIKE &apos;%what(EEAO-O162)%&apos; 
ORDER BY sur.ID_SERVICE_AUDIT_RESPONSE DESC
FETCH FIRST 1 ROWS ONLY</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">ID_SERVICE_AUDIT_RESPONSE, RESPONSE_DATE, RESPONSE, METADATA_RESPONSE, ID_SERVICE_AUDIT, CLIENT_IP, CLIENT_PORT, SERVICE, SERVICE_USER, REQUEST_DATE, REQUEST, METADATA, CONSUMER</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="hasData" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;ID_SERVICE_AUDIT_RESPONSE_#&quot;)?.trim()?.toInteger() ?: 0
def ok = (hasCount &gt;= 1)

prev.setSuccessful(ok)

def msg = ok 
    ? &quot;QUANTIDADE DE CANDITADOS: ${NISS_EE_1}&quot; 
    : &quot;[AVISO] NÃO TROUXE REGISTROS: ${hasCount}&quot;

prev.setResponseMessage(msg)
(ok ? log.info(msg) : log.error(msg))</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
