          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="VALIDA_QTT_ALERTA">
            <stringProp name="dataSource">devConnection </stringProp>
            <stringProp name="query">SELECT e.ID_ENTIDADE_COMUNICADA, e.NISS_EE,e.COMPROVATIVO_ENTREGA,
v.NISS_PS, alt.ID_REL_ALERTA_VALOR_COMUN_DIF,  v.TEMA, v.TEMA_HISTORICO_MENSAL
FROM EEAOC.entidade_COMUNICADA e
JOIN EEAOC.VALOR_COMUNICADO_DIFERENCA v
    ON e.id_entidade_comunicada = v.id_entidade_comunicada
JOIN EEAOC.rel_alerta_valor_comun_dif alt
ON v.ID_VALOR_COMUNICADO_DIFERENCA = alt.ID_VALOR_COMUNICADO_DIFERENCA
where e.COMPROVATIVO_ENTREGA = &apos;409e2611-a8c4-4917-9813-17bedb87dacd&apos;
--&apos;${comprovativosEntrega}&apos;</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">ID_ENTIDADE_COMUNICADA, NISS_EE, COMPROVATIVO_ENTREGA, NISS_PS, ID_REL_ALERTA_VALOR_COMUN_DIF, TEMA, TEMA_HISTORICO_MENSAL</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="hasData">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;ID_ENTIDADE_COMUNICADA_#&quot;)?.trim()?.toInteger() ?: 0

if (hasCount == 2) {
    log.info(&quot;Validação OK. Retornou ${hasCount} registros.&quot;)
} else {
    prev.setSuccessful(false)
    prev.setResponseMessage(&quot;Esperado 2 registros, retornou ${hasCount}&quot;)
    log.error(&quot;Falha na validação. Esperado 2 registros, retornou ${hasCount}&quot;)
}

</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
