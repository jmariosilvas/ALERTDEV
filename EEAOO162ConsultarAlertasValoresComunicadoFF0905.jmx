      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="randomNumber" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy ) {
	def rand = new Random()
	def primeiro = rand.nextInt(9) + 1
	def resto = (1..10).collect { rand.nextInt(10) }
	def numero = ([primeiro] + resto).join(&quot;&quot;)
	vars.put(&quot;nissPSRandom&quot;, numero)

}</stringProp>
      </JSR223PreProcessor>
      <hashTree/>
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="catchLabelAcertov2" enabled="false">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper
import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy) {

    def body = sampler.getArguments()?.getArgumentCount() &gt; 0 
        ? sampler.getArguments().getArgument(0).getValue() 
        : null

    if (!body) {
        log.info(&quot;Sem body (GET ou vazio)&quot;)
        vars.put(&quot;valorDoCampoAcerto&quot;, &quot;NAO_ENCONTRADO&quot;)
        return
    }

    try {
        def json = new JsonSlurper().parseText(body)
        def acerto = json?.valores?.getAt(0)?.acerto

        vars.put(&quot;valorDoCampoAcerto&quot;, acerto ?: &quot;NAO_ENCONTRADO&quot;)
        log.info(&quot;acerto: ${vars.get(&quot;valorDoCampoAcerto&quot;)}&quot;)

    } catch (Exception e) {
        log.info(&quot;JSON inválido&quot;)
        vars.put(&quot;valorDoCampoAcerto&quot;, &quot;ERRO_PARSE&quot;)
    }
}</stringProp>
      </JSR223PreProcessor>
