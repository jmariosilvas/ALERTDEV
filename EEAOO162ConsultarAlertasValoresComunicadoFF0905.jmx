      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="util_PostProcessor">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper


def expectField = { fieldName -&gt;
    def json = new JsonSlurper().parseText(prev.getResponseDataAsString())
    def value = json[fieldName]

    if (!value) {
        prev.setSuccessful(false)   
        prev.setResponseMessage(&quot;Campo &apos;${fieldName}&apos; não encontrado!&quot;)
        log.error(&quot;Campo &apos;${fieldName}&apos; não encontrado na resposta: ${prev.getResponseDataAsString()}&quot;)
    } else {
        vars.put(fieldName, value.toString()) 
        log.info(&quot;\n\nCampo &apos;${fieldName}&apos; extraído: ${value}&quot;)
    }
}


props.put(&quot;expectField&quot;, expectField)
log.info(&quot;\n/nFunção expectField carregada e disponível globalmente.&quot;)</stringProp>
        <stringProp name="TestPlan.comments">EEAOC-5.36.1-SNAPSHOT</stringProp>
      </JSR223PostProcessor>
      <hashTree/>
      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="formmaterBD" enabled="true">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">def sampler = ctx.getCurrentSampler()

if (sampler instanceof org.apache.jmeter.protocol.jdbc.sampler.JDBCSampler) {
	def response = prev.getResponseDataAsString()
	def linhas = response.split(&quot;\n&quot;).collect { it.trim() }
	def tabela = linhas.collect { it.split(/\s+/) }
	def larguras = []
	
	for (cols in tabela) {
	    for (int i = 0; i &lt; cols.size(); i++) {
	        def col = cols[i]
	        if (i &gt;= larguras.size()) {
	            larguras &lt;&lt; col.size()
	        } else if (col.size() &gt; larguras[i]) {
	            larguras[i] = col.size()
	        }
	    }
	}
	def output = []
	for (cols in tabela) {
	    def linha = []
	    for (int i = 0; i &lt; cols.size(); i++) {
	        linha &lt;&lt; cols[i].padRight(larguras[i])
	    }
	    output &lt;&lt; linha.join(&quot;  &quot;)
	}
	
	log.info(&quot;Tabela:\n&quot; + output.join(&quot;\n&quot;))
}</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223PostProcessor>
      <hashTree/>
      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="COMMONPRUEBAS" enabled="false">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">
import groovy.json.JsonSlurper
def status = prev.getResponseCode()
def body = prev.getResponseDataAsString()
prev.setSuccessful(true)
def requestFail(expected, actual) {
    prev.setSuccessful(false) 
    prev.setResponseMessage(&quot;Falha: Expected [${expected}], Returned [${actual}]&quot;)
    log.error(&quot;Request marcada como falha: Expected=${expected}, Returned=${actual}&quot;)
}

def renomearCT(){
	props.put(&quot;CT&quot;, ${__samplerName()})
}

if (props.get(&apos;NISSlength&apos;) == &quot;true&quot;) {
	def json = new JsonSlurper().parseText(body)
	def erros = []
	if (status != &quot;400&quot;) 
	{
	    erros &lt;&lt; &quot;Status diferente de 400: &quot; + status
	    log.error(&quot;\nStatus Code incorreto.&quot;)
	    requestFail(400, status)
	    
	}
	if (json.message != vars.get(&apos;nissFormatoInvalido&apos;)) 
	{
	    erros &lt;&lt; &quot;Mensagem inválida: &quot; + json.message
	    log.error(&quot;\nMessage diferente da esperada.&quot;)
	   requestFail(vars.get(&apos;nissFormatoInvalido&apos;), json.message)
	}
    props.put(&quot;NISSlength&quot;,&quot;false&quot;)

}

if (props.get(&apos;distinctNISS&apos;) == &quot;true&quot;) {
	
	def json = new JsonSlurper().parseText(body)
	def erros = []
	if (status != &quot;403&quot;) 
	{
	    erros &lt;&lt; &quot;Status diferente de 403: &quot; + status
	    log.error(&quot;\nStatus Code incorreto.&quot;)
	    requestFail(403, status)  
	}
	if (json.message != vars.get(&apos;msgDistinctNISS&apos;)) 
	{
	    erros &lt;&lt; &quot;Mensagem inválida: &quot; + json.message
	    log.error(&quot;\nMessage diferente da esperada.&quot;)
	   requestFail(vars.get(&apos;msgDistinctNISS&apos;), json.message)
	}

    props.put(&quot;distinctNISS&quot;,&quot;false&quot;)

}

//De momento ainda não é possivel
//
if (props.get(&apos;noRegistoPeriodoConfirmacao&apos;) == &quot;true&quot;) {
	
	def json = new JsonSlurper().parseText(body)
	def erros = []
	if (status != &quot;200&quot;) 
	{
	    erros &lt;&lt; &quot;Status diferente de 200: &quot; + status
	    log.error(&quot;\nStatus Code incorreto.&quot;)
	    requestFail(200, status)  
	}
	if (json.message != vars.get(&apos;msgNoRegistoPeriodoConfirmacao&apos;)) 
	{
	    erros &lt;&lt; &quot;Mensagem inválida: &quot; + json.message
	    log.error(&quot;\nMessage diferente da esperada.&quot;)
	   requestFail(vars.get(&apos;msgNoRegistoPeriodoConfirmacao&apos;), json.message)
	}
	if (json?.message == null) {
	    erros &lt;&lt; &quot;Campo &apos;message&apos; não encontrado no response&quot;
	    log.error(&quot;Campo &apos;message&apos; não existe no JSON de resposta.&quot;)
	    requestFail(vars.get(&quot;msgNoRegistoPeriodoConfirmacao&quot;), &quot;NULL&quot;)
	} 

    props.put(&quot;noRegistoPeriodoConfirmacao&quot;,&quot;false&quot;)

}

</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
